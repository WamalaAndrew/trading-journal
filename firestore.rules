rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { 
      allow read, write: if false; 
    }

    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isVerified() { return request.auth != null; }

    function isValidTrade(data) {
      return data.userId == request.auth.uid
        && data.dateTime is string
        && data.pair is string
        && data.timeframe is string
        && (!data.keys().hasAny(['macd4hDirection']) || data.macd4hDirection is string)
        && (!data.keys().hasAny(['macd1hCrossover']) || data.macd1hCrossover is string)
        && (!data.keys().hasAny(['rsiAtEntry']) || data.rsiAtEntry is number || data.rsiAtEntry is string)
        && (!data.keys().hasAny(['entryPrice']) || data.entryPrice is number || data.entryPrice is string)
        && (!data.keys().hasAny(['stopLossPrice']) || data.stopLossPrice is number || data.stopLossPrice is string)
        && (!data.keys().hasAny(['stopLossPips']) || data.stopLossPips is number || data.stopLossPips is string)
        && (!data.keys().hasAny(['takeProfitPrice']) || data.takeProfitPrice is number || data.takeProfitPrice is string)
        && (!data.keys().hasAny(['takeProfitRR']) || data.takeProfitRR is number || data.takeProfitRR is string)
        && (!data.keys().hasAny(['resultStatus']) || data.resultStatus is string)
        && (!data.keys().hasAny(['didWell']) || data.didWell is string)
        && (!data.keys().hasAny(['wouldChange']) || data.wouldChange is string)
        && (!data.keys().hasAny(['exitPrice']) || data.exitPrice is number || data.exitPrice is string)
        && (!data.keys().hasAny(['exitReason']) || data.exitReason is string)
        && (!data.keys().hasAny(['resultPips']) || data.resultPips is number || data.resultPips is string)
        && (!data.keys().hasAny(['notes']) || data.notes is string)
        && (!data.keys().hasAny(['strategyTags']) || data.strategyTags is list);
    }

    match /trades/{tradeId} {
      allow read: if isVerified() && resource.data.userId == request.auth.uid;
      allow create: if isVerified() && isValidId(tradeId) && isValidTrade(incoming()) && incoming().createdAt == request.time;
      allow update: if isVerified() && isValidId(tradeId) && isValidTrade(incoming()) 
                     && incoming().userId == existing().userId
                     && incoming().createdAt == existing().createdAt
                     && (incoming().diff(existing()).affectedKeys().size() == 0 || incoming().diff(existing()).affectedKeys().hasOnly(['dateTime', 'pair', 'timeframe', 'macd4hDirection', 'macd1hCrossover', 'rsiAtEntry', 'entryPrice', 'stopLossPrice', 'stopLossPips', 'takeProfitPrice', 'takeProfitRR', 'resultStatus', 'didWell', 'wouldChange', 'exitPrice', 'exitReason', 'resultPips', 'notes', 'strategyTags']));
      allow delete: if isVerified() && isValidId(tradeId) && existing().userId == request.auth.uid;
    }
  }
}
