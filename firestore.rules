rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { 
      allow read, write: if false; 
    }

    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isVerified() { return request.auth != null; }

    function isValidTrade(data) {
      return data.keys().hasAll(['userId', 'dateTime', 'createdAt', 'pair', 'timeframe', 'macd4hDirection', 'macd1hCrossover', 'rsiAtEntry', 'entryPrice', 'stopLossPrice', 'stopLossPips', 'takeProfitPrice', 'takeProfitRR', 'resultStatus', 'didWell', 'wouldChange'])
        && data.userId == request.auth.uid
        && data.dateTime is string && data.dateTime.size() <= 64
        && data.pair is string && data.pair.size() <= 20
        && data.timeframe is string && data.timeframe.size() <= 20
        && (data.macd4hDirection in ['Bullish', 'Bearish', 'Mixed'])
        && (data.macd1hCrossover in ['Above zero', 'Below zero'])
        && data.rsiAtEntry is number
        && data.entryPrice is number
        && data.stopLossPrice is number
        && data.stopLossPips is number
        && data.takeProfitPrice is number
        && data.takeProfitRR is number
        && (data.resultStatus in ['Win', 'Loss', 'Breakeven', 'Open/Pending'])
        && data.didWell is string && data.didWell.size() <= 2000
        && data.wouldChange is string && data.wouldChange.size() <= 2000
        && (!data.keys().hasAny(['exitPrice']) || data.exitPrice is number)
        && (!data.keys().hasAny(['exitReason']) || data.exitReason in ['Hit TP', 'Hit SL', 'MACD cross', 'RSI', 'Manual', 'Other'])
        && (!data.keys().hasAny(['resultPips']) || data.resultPips is number)
        && (!data.keys().hasAny(['notes']) || (data.notes is string && data.notes.size() <= 5000))
        && (!data.keys().hasAny(['strategyTags']) || (data.strategyTags is list && data.strategyTags.size() <= 10 && (data.strategyTags.size() == 0 || data.strategyTags[0] is string)));
    }

    match /trades/{tradeId} {
      allow read: if isVerified() && resource.data.userId == request.auth.uid;
      allow create: if isVerified() && isValidId(tradeId) && isValidTrade(incoming()) && incoming().createdAt == request.time;
      allow update: if isVerified() && isValidId(tradeId) && isValidTrade(incoming()) 
                     && incoming().userId == existing().userId
                     && incoming().createdAt == existing().createdAt
                     && incoming().diff(existing()).affectedKeys().hasAny(['dateTime', 'pair', 'timeframe', 'macd4hDirection', 'macd1hCrossover', 'rsiAtEntry', 'entryPrice', 'stopLossPrice', 'stopLossPips', 'takeProfitPrice', 'takeProfitRR', 'resultStatus', 'didWell', 'wouldChange', 'exitPrice', 'exitReason', 'resultPips', 'notes', 'strategyTags']);
      allow delete: if isVerified() && isValidId(tradeId) && existing().userId == request.auth.uid;
    }
  }
}
